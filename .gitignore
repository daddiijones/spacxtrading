# dependencies
/node_modules

# build output — tracked on purpose: this hosting account's shared
# Node environment can't run `vite build` (esbuild OOMs/crashes under
# CloudLinux's resource caps), so the built dist/ is committed and the
# server just `git pull`s the finished files. Rebuild + recommit locally
# whenever src/ changes. See DEPLOYMENT.md.

# env files (secrets — never commit these)
.env*

# misc
.DS_Store
*.pem

# debug
npm-debug.log*

# uploaded user content (runtime data, not source — app recreates this dir on startup)
/server/uploads

# editor
.vscode/*
!.vscode/extensions.json
